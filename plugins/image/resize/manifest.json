{
  "id": "img-resize",
  "name": "图片缩放",
  "description": "批量调整图片分辨率，指定宽度/高度/百分比缩放",
  "version": "0.1.0",
  "category": "image",
  "inputFormats": ["png", "jpg", "jpeg", "bmp", "webp", "tiff"],
  "outputFormats": ["png", "jpg", "webp"],
  "author": "Win Toolbox",
  "icon": "🖼️",
  "requiresPython": false,
  "configSchema": {
    "type": "object",
    "properties": {
      "mode": {
        "type": "string",
        "enum": ["percent", "width", "height", "fit"],
        "default": "percent"
      },
      "width": { "type": "number" },
      "height": { "type": "number" },
      "percent": { "type": "number", "default": 50 },
      "quality": { "type": "number", "default": 85, "minimum": 1, "maximum": 100 },
      "format": {
        "type": "string",
        "enum": ["same", "jpg", "png", "webp"],
        "default": "same"
      }
    }
  }
}
