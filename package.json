{
  "name": "win-toolbox",
  "version": "0.1.0",
  "description": "Windows toolbox for document conversion, video processing and image editing",
  "main": "out/main/index.js",
  "author": "Win Toolbox",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:electron": "electron-vite dev",
    "build": "electron-vite build",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder --win --x64 --publish never",
    "dist:portable": "npm run build && electron-builder --win portable --x64 --publish never",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "prepare:python": "node scripts/download-python.js",
    "prepare:ffmpeg": "node scripts/download-ffmpeg.js"
  },
  "dependencies": {
    "antd": "^5.21.0",
    "dayjs": "^1.11.13",
    "fluent-ffmpeg": "^2.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "sharp": "^0.33.5",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^32.1.2",
    "electron-builder": "^25.1.7",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
